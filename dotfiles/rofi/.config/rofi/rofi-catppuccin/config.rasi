configuration {
    kb-cancel: "Escape,Super_L";
    modes: [ drun, window, emoji ];
    font: "JetBrainsMono Nerd Font Medium 12";
    show-icons: true;
    icon-theme: "Papirus";
    drun-display-format: "{icon} {name}";
    
    /* Custom mode icons */
    drun {
        display-name: " ";
    }
    run {
        display-name: "";
    }
    window {
        display-name: "";
    }
}

@theme "~/.config/rofi/theme.rasi"
